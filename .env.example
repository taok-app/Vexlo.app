# Database
POSTGRES_URL=postgresql://user:password@localhost:5432/vexlo-ai

# GitHub OAuth
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_TOKEN=your_github_personal_access_token

# Vercel OAuth
NEXT_PUBLIC_VERCEL_CLIENT_ID=your_vercel_client_id
VERCEL_CLIENT_SECRET=your_vercel_client_secret

# Vercel Sandbox Integration
SANDBOX_VERCEL_TEAM_ID=your_vercel_team_id
SANDBOX_VERCEL_PROJECT_ID=your_vercel_project_id
SANDBOX_VERCEL_TOKEN=your_vercel_token

# AI Providers
AI_GATEWAY_API_KEY=your_ai_gateway_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_GENAI_USE_VERTEXAI=false
CURSOR_API_KEY=your_cursor_api_key

# Encryption
ENCRYPTION_KEY=your_encryption_key_32_chars_min
JWE_SECRET=your_jwe_secret_32_chars_min

# Rate Limiting
MAX_MESSAGES_PER_DAY=100
MAX_SANDBOX_DURATION=60m

# Environment
NODE_ENV=production
NEXT_PUBLIC_AUTH_PROVIDERS=github,vercel
